{
  "name": "hsdk",
  "version": "0.1.0",
  "description": "Harness SDK on Claude Agent SDK — planner + dispatcher + workers with hard approval gate",
  "type": "module",
  "bin": {
    "hsdk": "./dist/cli/index.js"
  },
  "main": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const f='dist/cli/index.js';const fs=require('fs');const s=fs.readFileSync(f,'utf8');if(!s.startsWith('#!'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+s);fs.chmodSync(f,0o755);\"",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "harness",
    "claude-agent-sdk",
    "planner",
    "dispatcher",
    "workers",
    "agent-orchestration"
  ],
  "author": "itstudyu",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "yaml": "^2.6.0",
    "zod": "^3.23.0",
    "picocolors": "^1.1.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
